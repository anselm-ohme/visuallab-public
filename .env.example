# Get a free key at https://build.nvidia.com (sign in, pick any model, "Get API Key").
NVIDIA_API_KEY=nvapi-REPLACE_ME
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=z-ai/glm4.7
NVIDIA_TIMEOUT=300
# Wikipedia's API ToS asks every script to identify itself with a real contact.
# Format: "<AppName> (<your-email>)"
WIKI_USER_AGENT=VisualLab (you@example.com)
WIKI_LANGUAGE=en

# Optional. Without a key the API still works but shares a low rate limit
# with all anonymous users. Request one at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
# Minimum seconds between Semantic Scholar requests. Their issued keys are
# typically capped at 1 req/sec — set this to 1.1 to stay safely under that.
SEMANTIC_SCHOLAR_RATE_LIMIT=1.1

# VisualRepo (GitHub). Optional but RECOMMENDED — without a token the
# unauthenticated quota is just 60 req/h per IP (5000/h with a token).
# Generate at https://github.com/settings/tokens (no scopes needed for public repos).
GITHUB_TOKEN=

# VisualArt — uses the Metropolitan Museum of Art's open API. No key required.

# Shareable dashboard storage. Defaults to ./data/shared/. Generated dashboard
# HTMLs are saved here when a user clicks "Copy share link" so /d/<slug> can
# serve them later. SHARE_RETENTION_DAYS controls how long unused shares live.
# (On Render's free tier the disk is ephemeral, so shares effectively last
# until the next deploy or wake-from-sleep regardless of this setting.)
SHARE_DIR=data/shared
SHARE_RETENTION_DAYS=30

# Email delivery (optional). When SMTP_USER + SMTP_PASSWORD + SMTP_FROM_EMAIL
# are all set, the UI exposes "Email this dashboard" and "Notify me when done"
# buttons. For Gmail, generate a 16-character "App password" at
# https://myaccount.google.com/apppasswords and put it in SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=VisualLab
SMTP_USE_SSL=false
